BOT_TOKEN=your_telegram_bot_token
MISTRAL_API_KEY=your_mistral_api_key

# Твой Telegram ID (можно узнать у @userinfobot)
ADMIN_USER_ID=123456789

# ID календаря — "primary" для основного
CALENDAR_ID=primary

# Временная зона
TIMEZONE=Europe/Moscow

# URL задеплоенного Next.js webapp (Railway)
# Если задан — в клавиатуре появится кнопка «Открыть приложение»
WEB_APP_URL=https://your-webapp.up.railway.app

# ID Telegram-группы, к которой привязан WebApp.
# Задания добавленные через webapp будут видны и в этой группе.
# Если не задан — задания хранятся только в webapp (chat_id=0).
WEBAPP_CHAT_ID=
